# Backend server
PORT=4000
ALLOWED_ORIGIN=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500,http://localhost:5173

# AI providers. Configure one or more; the server falls back to a local structured plan if empty.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Travel data providers
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test
GEOAPIFY_PLACES_API_KEY=
GEOAPIFY_GEOCODING_API_KEY=
BOOKING_PARTNER_ID=
TRIPCOM_PARTNER_ID=
