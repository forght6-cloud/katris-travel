# Vercel Serverless API environment variables
# Leave these blank for free/lightweight demo mode.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_USE_FALLBACK=true

# Amadeus
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test
AMADEUS_USE_MOCK=true

# Optional external booking affiliate marker
TRAVELPAYOUTS_MARKER=
